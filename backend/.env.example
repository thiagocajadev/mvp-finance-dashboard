ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5001

# Banco de dados
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=finance_dashboard;Username=postgres;Password=yourpassword

# JWT
Jwt__SecretKey=your-secret-key-at-least-32-chars
Jwt__Issuer=finance-dashboard
Jwt__Audience=finance-dashboard
Jwt__ExpiresInMinutes=60

# CORS
Cors__Origin=http://localhost:5173
