# Copie este arquivo para .env e ajuste os valores.
# O arquivo .env é gitignored — nunca commite credenciais.

# ─── Dev ─────────────────────────────────────────────────────────────────────
# URL do backend local para o proxy do Vite (não é exposto ao browser)
BACKEND_URL=http://localhost:5001

# ─── Prod ─────────────────────────────────────────────────────────────────────
# URL completa da API em produção, incluindo o prefixo /api/v1. Em dev, deixar vazio — o proxy cuida.
VITE_API_URL=
